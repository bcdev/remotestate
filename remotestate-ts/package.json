{
  "name": "remotestate",
  "version": "0.3.3",
  "description": "Python state, React UI.",
  "type": "module",
  "main": "./dist/remotestate.js",
  "types": "./dist/remotestate.d.ts",
  "license": "MIT",
  "author": "forman",
  "homepage": "https://github.com/bcdev/remotestate#readme",
  "bugs": {
    "url": "https://github.com/bcdev/remotestate/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bcdev/remotestate.git",
    "directory": "remotestate-ts"
  },
  "keywords": [
    "react",
    "typescript",
    "state",
    "websocket",
    "hooks"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/remotestate.js",
      "types": "./dist/remotestate.d.ts"
    },
    "./path": {
      "import": "./dist/path.js",
      "types": "./dist/path.d.ts"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "rimraf dist && vite build --configLoader runner && tsc -b --force",
    "tests": "vitest run",
    "checks": "tsc -b --noEmit && eslint src",
    "format": "prettier -w ."
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@microsoft/api-extractor": "^7.58.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "dts-bundle-generator": "^9.5.1",
    "eslint": "^9.0.0",
    "prettier": "^3.8.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.5"
  },
  "allowScripts": {
    "esbuild@0.25.12": true
  }
}
